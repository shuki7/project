# Notion API
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram Bot
TELEGRAM_TOKEN=0000000000:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# カンマ区切りで許可するTelegramユーザーIDを指定（空欄=全員許可）
TELEGRAM_ALLOWED_USERS=123456789

# Anthropic Claude API（OCR・自動分類に使用）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Google Drive
# Driveのフォルダを右クリック→共有リンクのIDをここに貼る
GDRIVE_FOLDER_ID=1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ローカルのGoogle Driveフォルダパス（自動同期している場合）
# 例: /Users/yourname/Google Drive/My Drive
GDRIVE_LOCAL_PATH=/Users/yourname/Google Drive/My Drive/家計簿
